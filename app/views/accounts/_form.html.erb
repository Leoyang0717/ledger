<%= form_with model: account, class: "space-y-8" do |f| %>
  <% if account.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <div class="text-base text-red-700">
        <ul class="list-disc pl-5 space-y-1">
          <% account.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "帳戶名稱", class: "block text-base font-medium text-gray-700 mb-2" %>
    <%= f.text_field :name, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-lg py-3 px-4", placeholder: "例如：主帳戶" %>
  </div>

  <div>
    <%= f.label :account_type, "帳戶類型", class: "block text-base font-medium text-gray-700 mb-2" %>
    <%= f.select :account_type, Account.account_types.keys.map { |k| [t("account_types.#{k}"), k] }, {}, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-lg py-3 px-4" %>
  </div>

  <div>
    <%= f.label :initial_balance, "初始餘額", class: "block text-base font-medium text-gray-700 mb-2" %>
    <%= f.number_field :initial_balance, step: 1, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-lg py-3 px-4", placeholder: "0" %>
    <p class="mt-2 text-base text-gray-500">輸入這個帳戶目前的餘額作為起始值</p>
  </div>

  <div class="flex justify-end space-x-4 pt-4">
    <%= link_to "取消", accounts_path, class: "inline-flex items-center px-6 py-3 border border-gray-300 text-base font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50" %>
    <%= f.submit account.persisted? ? "更新帳戶" : "新增帳戶", class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-lg shadow-sm text-white bg-blue-600 hover:bg-blue-700 cursor-pointer" %>
  </div>
<% end %>
