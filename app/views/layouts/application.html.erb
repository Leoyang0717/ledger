<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "記帳本" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Ledger">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 min-h-screen">
    <nav class="bg-white shadow-sm border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex">
            <%= link_to "記帳本", root_path, class: "flex items-center text-xl font-bold text-gray-900" %>
            <div class="hidden sm:ml-8 sm:flex sm:space-x-4">
              <%= link_to "總覽", root_path, class: "inline-flex items-center px-3 py-2 text-sm font-medium #{current_page?(root_path) ? 'text-blue-600' : 'text-gray-500 hover:text-gray-700'}" %>
              <%= link_to "記帳", entries_path, class: "inline-flex items-center px-3 py-2 text-sm font-medium #{controller_name == 'entries' ? 'text-blue-600' : 'text-gray-500 hover:text-gray-700'}" %>
              <%= link_to "帳戶", accounts_path, class: "inline-flex items-center px-3 py-2 text-sm font-medium #{controller_name == 'accounts' ? 'text-blue-600' : 'text-gray-500 hover:text-gray-700'}" %>
              <%= link_to "常用項目", quick_entries_path, class: "inline-flex items-center px-3 py-2 text-sm font-medium #{controller_name == 'quick_entries' ? 'text-blue-600' : 'text-gray-500 hover:text-gray-700'}" %>
              <%= link_to "分類", categories_path, class: "inline-flex items-center px-3 py-2 text-sm font-medium #{controller_name == 'categories' ? 'text-blue-600' : 'text-gray-500 hover:text-gray-700'}" %>
              <%= link_to "演唱會試算", concert_calculator_path, class: "inline-flex items-center px-3 py-2 text-sm font-medium #{controller_name == 'concert_calculator' ? 'text-blue-600' : 'text-gray-500 hover:text-gray-700'}" %>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8">
      <% if notice.present? %>
        <div class="mb-4 rounded-md bg-green-50 p-4">
          <p class="text-sm font-medium text-green-800"><%= notice %></p>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="mb-4 rounded-md bg-red-50 p-4">
          <p class="text-sm font-medium text-red-800"><%= alert %></p>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
