<% content_for :title, "追星冷靜計算器" %>

<div data-controller="concert-calculator">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">追星冷靜計算器</h1>
    <p class="text-sm text-gray-400 mt-1">依地點分類規劃行程，計算預計花費</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">

    <!-- 左：各類別區塊 -->
    <div class="lg:col-span-2 space-y-4">

      <!-- 費用設定 -->
      <details class="bg-white rounded-xl border border-gray-200 shadow-sm group">
        <summary class="px-6 py-4 cursor-pointer flex items-center gap-2 select-none list-none">
          <svg class="w-4 h-4 text-gray-400 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <span class="text-sm font-semibold text-gray-700">費用設定</span>
          <span class="text-xs text-gray-400">（點開可依個人情況調整基準費用）</span>
        </summary>
        <div class="px-6 pb-6 border-t border-gray-100 pt-4 grid grid-cols-2 gap-x-6 gap-y-4">

          <div>
            <div class="text-xs font-medium text-gray-500 mb-2">台灣場</div>
            <div class="space-y-2">
              <div class="flex items-center justify-between gap-2">
                <label class="text-xs text-gray-500 whitespace-nowrap">門票/場</label>
                <input type="number" data-setting-group="taiwan" data-setting-field="ticket" value="6000" min="0" step="500" data-action="input->concert-calculator#settingChanged" class="w-28 text-sm border border-gray-200 rounded-lg px-2 py-1 text-right focus:outline-none focus:ring-2 focus:ring-blue-400">
              </div>
              <div class="flex items-center justify-between gap-2">
                <label class="text-xs text-gray-500 whitespace-nowrap">交通（固定）</label>
                <input type="number" data-setting-group="taiwan" data-setting-field="transport" value="3000" min="0" step="500" data-action="input->concert-calculator#settingChanged" class="w-28 text-sm border border-gray-200 rounded-lg px-2 py-1 text-right focus:outline-none focus:ring-2 focus:ring-blue-400">
              </div>
              <div class="flex items-center justify-between gap-2">
                <label class="text-xs text-gray-500 whitespace-nowrap">雜支/趟</label>
                <input type="number" data-setting-group="taiwan" data-setting-field="misc" value="200" min="0" step="100" data-action="input->concert-calculator#settingChanged" class="w-28 text-sm border border-gray-200 rounded-lg px-2 py-1 text-right focus:outline-none focus:ring-2 focus:ring-blue-400">
              </div>
            </div>
          </div>

          <div>
            <div class="text-xs font-medium text-gray-500 mb-2">海外共用</div>
            <div class="space-y-2">
              <div class="flex items-center justify-between gap-2">
                <label class="text-xs text-gray-500 whitespace-nowrap">住宿/晚</label>
                <input type="number" data-setting-group="shared" data-setting-field="accommodation" value="2000" min="0" step="500" data-action="input->concert-calculator#settingChanged" class="w-28 text-sm border border-gray-200 rounded-lg px-2 py-1 text-right focus:outline-none focus:ring-2 focus:ring-blue-400">
              </div>
              <div class="flex items-center justify-between gap-2">
                <label class="text-xs text-gray-500 whitespace-nowrap">伙食/天</label>
                <input type="number" data-setting-group="shared" data-setting-field="food" value="1000" min="0" step="500" data-action="input->concert-calculator#settingChanged" class="w-28 text-sm border border-gray-200 rounded-lg px-2 py-1 text-right focus:outline-none focus:ring-2 focus:ring-blue-400">
              </div>
            </div>
          </div>

          <div>
            <div class="text-xs font-medium text-gray-500 mb-2">韓國場</div>
            <div class="space-y-2">
              <div class="flex items-center justify-between gap-2">
                <label class="text-xs text-gray-500 whitespace-nowrap">門票/場</label>
                <input type="number" data-setting-group="korea" data-setting-field="ticket" value="4000" min="0" step="500" data-action="input->concert-calculator#settingChanged" class="w-28 text-sm border border-gray-200 rounded-lg px-2 py-1 text-right focus:outline-none focus:ring-2 focus:ring-blue-400">
              </div>
              <div class="flex items-center justify-between gap-2">
                <label class="text-xs text-gray-500 whitespace-nowrap">交通（固定）</label>
                <input type="number" data-setting-group="korea" data-setting-field="transport" value="10000" min="0" step="500" data-action="input->concert-calculator#settingChanged" class="w-28 text-sm border border-gray-200 rounded-lg px-2 py-1 text-right focus:outline-none focus:ring-2 focus:ring-blue-400">
              </div>
              <div class="flex items-center justify-between gap-2">
                <label class="text-xs text-gray-500 whitespace-nowrap">雜支/趟</label>
                <input type="number" data-setting-group="korea" data-setting-field="misc" value="1000" min="0" step="100" data-action="input->concert-calculator#settingChanged" class="w-28 text-sm border border-gray-200 rounded-lg px-2 py-1 text-right focus:outline-none focus:ring-2 focus:ring-blue-400">
              </div>
            </div>
          </div>

          <div>
            <div class="text-xs font-medium text-gray-500 mb-2">日本場</div>
            <div class="space-y-2">
              <div class="flex items-center justify-between gap-2">
                <label class="text-xs text-gray-500 whitespace-nowrap">門票/場</label>
                <input type="number" data-setting-group="japan" data-setting-field="ticket" value="5500" min="0" step="500" data-action="input->concert-calculator#settingChanged" class="w-28 text-sm border border-gray-200 rounded-lg px-2 py-1 text-right focus:outline-none focus:ring-2 focus:ring-blue-400">
              </div>
              <div class="flex items-center justify-between gap-2">
                <label class="text-xs text-gray-500 whitespace-nowrap">交通（固定）</label>
                <input type="number" data-setting-group="japan" data-setting-field="transport" value="13000" min="0" step="500" data-action="input->concert-calculator#settingChanged" class="w-28 text-sm border border-gray-200 rounded-lg px-2 py-1 text-right focus:outline-none focus:ring-2 focus:ring-blue-400">
              </div>
              <div class="flex items-center justify-between gap-2">
                <label class="text-xs text-gray-500 whitespace-nowrap">雜支/趟</label>
                <input type="number" data-setting-group="japan" data-setting-field="misc" value="1500" min="0" step="100" data-action="input->concert-calculator#settingChanged" class="w-28 text-sm border border-gray-200 rounded-lg px-2 py-1 text-right focus:outline-none focus:ring-2 focus:ring-blue-400">
              </div>
            </div>
          </div>

          <div>
            <div class="text-xs font-medium text-gray-500 mb-2">簽售會</div>
            <div class="space-y-2">
              <div class="flex items-center justify-between gap-2">
                <label class="text-xs text-gray-500 whitespace-nowrap">上台</label>
                <input type="number" data-setting-group="signing" data-setting-field="onstage" value="70000" min="0" step="1000" data-action="input->concert-calculator#settingChanged" class="w-28 text-sm border border-gray-200 rounded-lg px-2 py-1 text-right focus:outline-none focus:ring-2 focus:ring-blue-400">
              </div>
              <div class="flex items-center justify-between gap-2">
                <label class="text-xs text-gray-500 whitespace-nowrap">觀禮</label>
                <input type="number" data-setting-group="signing" data-setting-field="audience" value="15000" min="0" step="1000" data-action="input->concert-calculator#settingChanged" class="w-28 text-sm border border-gray-200 rounded-lg px-2 py-1 text-right focus:outline-none focus:ring-2 focus:ring-blue-400">
              </div>
            </div>
          </div>

        </div>
      </details>

      <!-- 台灣場 -->
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
        <div class="px-6 pt-6 pb-4 pr-6">
          <div class="flex items-center gap-2 mb-1">
            <div class="w-2.5 h-2.5 rounded-full bg-blue-400 shrink-0"></div>
            <h2 class="text-base font-semibold text-gray-800">台灣場</h2>
          </div>
          <p class="text-xs text-gray-400 pl-[18px]">高雄 · 門票 NT$6,000/場 · 交通 NT$3,000（固定）</p>
        </div>
        <div class="px-4 pb-2">
          <div data-concert-calculator-target="taiwanList" class="space-y-2"></div>
        </div>
        <div class="px-6 py-4 border-t border-gray-100">
          <button
            data-action="click->concert-calculator#addTaiwan"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-blue-500 border border-blue-200 bg-blue-50 hover:bg-blue-100 px-3 py-1.5 rounded-lg transition-colors"
          >+ 新增台灣場</button>
        </div>
      </div>

      <!-- 韓國場 -->
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
        <div class="px-6 pt-6 pb-4 pr-6">
          <div class="flex items-center gap-2 mb-1">
            <div class="w-2.5 h-2.5 rounded-full bg-rose-400 shrink-0"></div>
            <h2 class="text-base font-semibold text-gray-800">韓國場</h2>
          </div>
          <p class="text-xs text-gray-400 pl-[18px]">門票 NT$4,000/場 · 交通 NT$10,000 · 住宿 NT$2,000/晚 · 伙食 NT$1,000/天</p>
        </div>
        <div class="px-4 pb-2">
          <div data-concert-calculator-target="koreaList" class="space-y-2"></div>
        </div>
        <div class="px-6 py-4 border-t border-gray-100">
          <button
            data-action="click->concert-calculator#addKorea"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-blue-500 border border-blue-200 bg-blue-50 hover:bg-blue-100 px-3 py-1.5 rounded-lg transition-colors"
          >+ 新增韓國行程</button>
        </div>
      </div>

      <!-- 日本場 -->
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
        <div class="px-6 pt-6 pb-4 pr-6">
          <div class="flex items-center gap-2 mb-1">
            <div class="w-2.5 h-2.5 rounded-full bg-fuchsia-400 shrink-0"></div>
            <h2 class="text-base font-semibold text-gray-800">日本場</h2>
          </div>
          <p class="text-xs text-gray-400 pl-[18px]">門票 NT$5,500/場 · 交通 NT$13,000 · 住宿 NT$2,000/晚 · 伙食 NT$1,000/天</p>
        </div>
        <div class="px-4 pb-2">
          <div data-concert-calculator-target="japanList" class="space-y-2"></div>
        </div>
        <div class="px-6 py-4 border-t border-gray-100">
          <button
            data-action="click->concert-calculator#addJapan"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-blue-500 border border-blue-200 bg-blue-50 hover:bg-blue-100 px-3 py-1.5 rounded-lg transition-colors"
          >+ 新增日本行程</button>
        </div>
      </div>

      <!-- 簽售會 -->
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
        <div class="px-6 pt-6 pb-4 pr-6">
          <div class="flex items-center gap-2 mb-1">
            <div class="w-2.5 h-2.5 rounded-full bg-purple-400 shrink-0"></div>
            <h2 class="text-base font-semibold text-gray-800">簽售會</h2>
          </div>
          <p class="text-xs text-gray-400 pl-[18px]">上台 NT$70,000 · 觀禮 NT$15,000</p>
        </div>
        <div class="px-4 pb-2">
          <div data-concert-calculator-target="signingList" class="space-y-2"></div>
        </div>
        <div class="px-6 py-4 border-t border-gray-100 flex gap-4">
          <button
            data-action="click->concert-calculator#addSigningOnstage"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-blue-500 border border-blue-200 bg-blue-50 hover:bg-blue-100 px-3 py-1.5 rounded-lg transition-colors"
          >+ 上台</button>
          <button
            data-action="click->concert-calculator#addSigningAudience"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-blue-500 border border-blue-200 bg-blue-50 hover:bg-blue-100 px-3 py-1.5 rounded-lg transition-colors"
          >+ 觀禮</button>
        </div>
      </div>

      <!-- 其他開銷 -->
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
        <div class="px-6 pt-6 pb-4 pr-6">
          <div class="flex items-center gap-2 mb-1">
            <div class="w-2.5 h-2.5 rounded-full bg-amber-400 shrink-0"></div>
            <h2 class="text-base font-semibold text-gray-800">其他開銷</h2>
          </div>
          <p class="text-xs text-gray-400 pl-[18px]">自訂項目與金額，一併納入總預算</p>
        </div>
        <div class="px-4 pb-2">
          <div data-concert-calculator-target="otherList" class="space-y-2"></div>
        </div>
        <div class="px-6 py-4 border-t border-gray-100">
          <button
            data-action="click->concert-calculator#addOther"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-blue-500 border border-blue-200 bg-blue-50 hover:bg-blue-100 px-3 py-1.5 rounded-lg transition-colors"
          >+ 新增項目</button>
        </div>
      </div>

    </div>

    <!-- 右：費用摘要 + 存款試算 -->
    <div class="lg:col-span-1 sticky top-6 space-y-4">
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
        <h2 class="text-base font-semibold text-gray-800 mb-5">總費用摘要</h2>

        <!-- 演唱會 -->
        <div class="mb-4">
          <div class="flex items-center gap-1.5 mb-3">
            <div class="w-2 h-2 rounded-full bg-blue-400"></div>
            <span class="text-xs font-medium text-gray-400 uppercase tracking-wide">演唱會</span>
          </div>
          <div class="space-y-2 pl-3.5">
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">門票</span>
              <span data-concert-calculator-target="grandTicket" class="font-medium text-gray-700">NT$ 0</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">交通</span>
              <span data-concert-calculator-target="grandTransport" class="font-medium text-gray-700">NT$ 0</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">住宿</span>
              <span data-concert-calculator-target="grandAccommodation" class="font-medium text-gray-700">NT$ 0</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">伙食</span>
              <span data-concert-calculator-target="grandFood" class="font-medium text-gray-700">NT$ 0</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">雜支</span>
              <span data-concert-calculator-target="grandMisc" class="font-medium text-gray-700">NT$ 0</span>
            </div>
            <div class="flex justify-between text-sm font-semibold pt-2 border-t border-gray-100">
              <span class="text-gray-600">演唱會小計</span>
              <span data-concert-calculator-target="grandConcert" class="text-blue-500">NT$ 0</span>
            </div>
          </div>
        </div>

        <!-- 簽售會 -->
        <div class="mb-4">
          <div class="flex items-center gap-1.5 mb-3">
            <div class="w-2 h-2 rounded-full bg-purple-400"></div>
            <span class="text-xs font-medium text-gray-400 uppercase tracking-wide">簽售會</span>
          </div>
          <div class="pl-3.5">
            <div class="flex justify-between text-sm font-semibold">
              <span class="text-gray-600">簽售會小計</span>
              <span data-concert-calculator-target="grandSigning" class="text-purple-500">NT$ 0</span>
            </div>
          </div>
        </div>

        <!-- 其他開銷 -->
        <div class="mb-4">
          <div class="flex items-center gap-1.5 mb-3">
            <div class="w-2 h-2 rounded-full bg-amber-400"></div>
            <span class="text-xs font-medium text-gray-400 uppercase tracking-wide">其他開銷</span>
          </div>
          <div class="pl-3.5">
            <div class="flex justify-between text-sm font-semibold">
              <span class="text-gray-600">其他開銷小計</span>
              <span data-concert-calculator-target="grandOther" class="text-amber-500">NT$ 0</span>
            </div>
          </div>
        </div>

        <!-- 總計 -->
        <div class="flex justify-between items-baseline pt-4 border-t-2 border-gray-200">
          <span class="font-bold text-gray-900">總計</span>
          <span data-concert-calculator-target="grandTotal" class="text-2xl font-bold text-gray-900">NT$ 0</span>
        </div>

        <!-- 費用基準 -->
        <details class="mt-6">
          <summary class="text-xs text-gray-400 cursor-pointer hover:text-gray-500 select-none">費用基準參考</summary>
          <div class="mt-3 space-y-1 pl-1">
            <div class="flex justify-between text-xs text-gray-400"><span>台灣票價</span><span>NT$ 6,000/場</span></div>
            <div class="flex justify-between text-xs text-gray-400"><span>韓國票價</span><span>NT$ 4,000/場</span></div>
            <div class="flex justify-between text-xs text-gray-400"><span>日本票價</span><span>NT$ 5,500/場</span></div>
            <div class="flex justify-between text-xs text-gray-400 mt-2"><span>台灣交通</span><span>NT$ 3,000</span></div>
            <div class="flex justify-between text-xs text-gray-400"><span>韓國交通</span><span>NT$ 10,000</span></div>
            <div class="flex justify-between text-xs text-gray-400"><span>日本交通</span><span>NT$ 13,000</span></div>
            <div class="flex justify-between text-xs text-gray-400 mt-2"><span>簽售 上台</span><span>NT$ 70,000</span></div>
            <div class="flex justify-between text-xs text-gray-400"><span>簽售 觀禮</span><span>NT$ 15,000</span></div>
          </div>
        </details>
      </div>

      <!-- 存款試算 -->
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
        <h2 class="text-base font-semibold text-gray-800 mb-4">存款試算</h2>

        <div class="mb-4">
          <label class="block text-xs font-medium text-gray-500 mb-1.5">每月可存金額</label>
          <div class="flex items-center gap-2">
            <input
              type="number"
              data-concert-calculator-target="monthlySavings"
              data-action="input->concert-calculator#inputChanged"
              placeholder="0"
              min="0"
              step="1000"
              class="flex-1 text-sm border border-gray-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent text-right tabular-nums"
            />
            <span class="text-sm text-gray-400 whitespace-nowrap">元 / 月</span>
          </div>
        </div>

        <div class="space-y-2 mb-4">
          <div class="flex justify-between text-sm">
            <span class="text-gray-500">一年可存</span>
            <span data-concert-calculator-target="annualSavings" class="font-medium text-gray-700">NT$ 0</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-gray-500">目標總額</span>
            <span data-concert-calculator-target="savingsGoal" class="font-medium text-gray-700">NT$ 0</span>
          </div>
        </div>

        <div data-concert-calculator-target="savingsStatus">
          <div class="rounded-lg bg-gray-50 border border-gray-100 px-4 py-3">
            <p class="text-xs text-gray-400">輸入每月存款金額以試算</p>
          </div>
        </div>

        <div class="mt-4 pt-4 border-t border-gray-100 space-y-2">
          <div class="flex justify-between text-sm">
            <span class="text-gray-500">已記錄花費</span>
            <span data-concert-calculator-target="actualSpent" class="font-medium text-emerald-600">NT$ 0</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-gray-500">剩下可花</span>
            <span data-concert-calculator-target="remainingBudget" class="font-medium text-gray-700">NT$ 0</span>
          </div>
        </div>
      </div>

    </div>

  </div>
</div>
