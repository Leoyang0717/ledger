<%= form_with model: category, class: "space-y-8" do |f| %>
  <% if category.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <div class="text-base text-red-700">
        <ul class="list-disc pl-5 space-y-1">
          <% category.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "分類名稱", class: "block text-base font-medium text-gray-700 mb-2" %>
    <%= f.text_field :name, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-lg py-3 px-4", placeholder: "例如：伙食費" %>
  </div>

  <div>
    <%= f.label :transaction_type, "分類類型", class: "block text-base font-medium text-gray-700 mb-2" %>
    <%= f.select :transaction_type, Category.transaction_types.keys.map { |k| [t("transaction_types.#{k}"), k] }, {}, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-lg py-3 px-4" %>
  </div>

  <div class="flex justify-end space-x-4 pt-4">
    <%= link_to "取消", categories_path, class: "inline-flex items-center px-6 py-3 border border-gray-300 text-base font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50" %>
    <%= f.submit category.persisted? ? "更新分類" : "新增分類", class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-lg shadow-sm text-white bg-blue-600 hover:bg-blue-700 cursor-pointer" %>
  </div>
<% end %>
